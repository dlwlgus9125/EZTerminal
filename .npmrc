node-linker = hoisted

# cap (Phase 2B packet capture, node-gyp-compiled) picks up `@electron/node-gyp`
# (hoisted transitively via electron-forge) instead of plain npm's node-gyp.
# That fork inherits `clang` from the CURRENTLY RUNNING node's own
# process.config — and this machine's global Node.js v24.14.0 was itself built
# with clang=1 — which forces the MSBuild `ClangCL` platform toolset. This
# VS2022 Build Tools install only has the standard MSVC v143 toolset (no
# "C++ Clang tools for Windows" component), so the ClangCL build fails with
# MSB8020. Forcing clang=0 here routes the build back to plain MSVC, which is
# what's actually installed (confirmed working manually via
# `node-gyp rebuild --clang=0`).
clang = false

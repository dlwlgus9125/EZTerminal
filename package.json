{
  "name": "ezterminal",
  "version": "0.1.0",
  "description": "EZTerminal - Electron-based local terminal emulator",
  "private": true,
  "main": ".vite/build/index.js",
  "scripts": {
    "dev": "electron-forge start",
    "build": "electron-forge make",
    "package": "electron-forge package",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "build:e2e": "node scripts/build-e2e.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "verify:externals": "node scripts/verify-externals.mjs",
    "dist:smoke": "node scripts/dist-smoke.mjs"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.24",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-unicode11": "^0.8.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "chokidar": "^5.0.0",
    "electron-log": "^5.4.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "node-pty": "^1.0.0",
    "systeminformation": "^5.23.27",
    "zustand": "^5.0.5"
  },
  "optionalDependencies": {
    "cap": "^0.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@electron-forge/cli": "^7.8.1",
    "@electron-forge/maker-squirrel": "^7.8.1",
    "@electron-forge/maker-zip": "^7.8.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.8.1",
    "@electron-forge/plugin-vite": "^7.8.1",
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.17",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.3",
    "@vitejs/plugin-react": "^4.5.0",
    "@vitest/coverage-v8": "^3.2.0",
    "electron": "^36.3.1",
    "electron-rebuild": "^3.2.9",
    "jsdom": "^26.1.0",
    "playwright": "^1.52.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.0"
  },
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "electron",
      "electron-winstaller",
      "esbuild",
      "lzma-native",
      "node-pty"
    ]
  }
}

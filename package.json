{
  "name": "ezterminal",
  "productName": "EZTerminal",
  "version": "0.9.0",
  "description": "EZTerminal — a structured-data shell terminal (Phase 1 shell core).",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "lint": "eslint --ext .ts,.tsx .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "test:e2e:packaged": "playwright test --config playwright.packaged.config.ts",
    "guard:native": "node scripts/guard-native-pty.mjs",
    "guard:native-cap": "node scripts/guard-native-cap.mjs",
    "guard:pty-routing": "node scripts/guard-pty-routing.mjs"
  },
  "keywords": [],
  "author": {
    "name": "EZTerminal"
  },
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "cap",
      "electron",
      "electron-winstaller",
      "node-pty"
    ],
    "overrides": {
      "tar": ">=7.5.16",
      "tmp": ">=0.2.4",
      "@capacitor/cli>tar": "^6.1.11"
    },
    "patchedDependencies": {
      "capacitor-secure-storage-plugin@0.10.0": "patches/capacitor-secure-storage-plugin@0.10.0.patch"
    }
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "@fontsource/fira-code": "^5.2.7",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@playwright/test": "^1.49.1",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ssh2": "^1.15.5",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "42.5.0",
    "electron-winstaller": "^5.4.2",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "png2icons": "^2.0.1",
    "typescript": "^5.5.4",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "0.16.0",
    "@xterm/addon-serialize": "0.14.0",
    "@xterm/addon-unicode11": "0.9.0",
    "@xterm/addon-web-links": "0.12.0",
    "@xterm/addon-webgl": "0.19.0",
    "@xterm/headless": "6.0.0",
    "@xterm/xterm": "^6.0.0",
    "ansi_up": "^6.0.6",
    "cap": "^0.2.1",
    "cross-spawn": "^7.0.6",
    "dockview-react": "^7.0.2",
    "electron-squirrel-startup": "^1.0.1",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "ssh2": "^1.17.0",
    "systeminformation": "5.31.11",
    "tslib": "^2.8.1",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  }
}

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock
.DS_Store

# Dependency directories
node_modules/
jspm_packages/

# AC-5 (CLI-parity M5) fixture deliberately shaped like an npm cmd-shim install
# (node_modules/.bin/*.cmd) to exercise buildCmdLine's shim double-escape path —
# un-ignore it explicitly (git requires negating each directory in the chain).
!e2e/fixtures/node_modules/
!e2e/fixtures/node_modules/.bin/
!e2e/fixtures/node_modules/.bin/dlx-shim.cmd

# TypeScript cache
*.tsbuildinfo

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# dotenv environment variables file
.env
.env.test

# Vite
.vite/

# Electron-Forge build output
out/
# Env-gated alternate output dir (forge.config.ts EZ_OUT_DIR workaround)
out-run/
out-*/

# Generic build output
dist/

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# oh-my-claudecode operational state (keep committable skills only)
.omc/
!.omc/skills/

# Claude Code local/personal settings (machine-specific)
.claude/settings.local.json

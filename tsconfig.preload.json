{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./.vite/build/preload",
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "jsx": "react-jsx"
  },
  "include": ["src/preload/**/*"],
  "exclude": ["node_modules", "out", ".vite"]
}

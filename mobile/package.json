{
  "name": "ezterminal-mobile",
  "version": "0.9.0",
  "private": true,
  "description": "EZTerminal mobile remote control — reuses the desktop renderer's BlockController/Block components over a WS transport (mobile remote-control plan, M1+).",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --no-ignore --config ../.eslintrc.json --ext .ts,.tsx \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "cap:sync": "cap sync android",
    "e2e:smoke": "node e2e/smoke.ts",
    "e2e:parity": "node e2e/parity.ts"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/browser": "^6.0.6",
    "@capacitor/core": "^6.2.0",
    "@capacitor/filesystem": "^6.0.4",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "0.16.0",
    "@xterm/addon-unicode11": "0.9.0",
    "@xterm/addon-web-links": "0.12.0",
    "@xterm/addon-webgl": "0.19.0",
    "@xterm/xterm": "^6.0.0",
    "ansi_up": "^6.0.6",
    "capacitor-secure-storage-plugin": "0.10.0",
    "i18next": "^26.3.6",
    "lucide-react": "^1.24.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.9",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "@playwright/test": "^1.49.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.5.4",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  }
}

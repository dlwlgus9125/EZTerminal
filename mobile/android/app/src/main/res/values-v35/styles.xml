<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 15 enforces edge-to-edge for targetSdk 35. Capacitor 6's
         WebView can report a zero safe-area inset even while the status bar
         overlaps the header, leaving its buttons untappable. Keep the API 35
         attribute out of the base resource table so API 22-34 stay safe. -->
    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <item name="android:windowOptOutEdgeToEdgeEnforcement">true</item>
    </style>
</resources>

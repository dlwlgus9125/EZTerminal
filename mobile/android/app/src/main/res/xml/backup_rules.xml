<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- Saved connection material is encrypted with a device-local Android
         Keystore key. Restoring only the ciphertext creates unusable state. -->
    <exclude domain="root" path="." />
    <exclude domain="file" path="." />
    <exclude domain="database" path="." />
    <exclude domain="sharedpref" path="." />
    <exclude domain="external" path="." />
</full-backup-content>

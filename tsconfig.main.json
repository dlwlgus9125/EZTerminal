{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./.vite/build/main",
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "jsx": "react-jsx"
  },
  "include": ["src/main/**/*", "forge.config.ts"],
  "exclude": ["node_modules", "out", ".vite"]
}
